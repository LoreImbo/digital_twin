# ─────────────────────────────────────────────────────────────────────────────
#  .env.example – Variabili d'ambiente per azure_connector.py
#  Copia questo file in ".env" e compila le variabili necessarie.
#  Il file .env NON va mai committato su Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure IoT Hub (EventHub-compatible endpoint) ──────────────────────────────
#
# Dove trovarlo:
#   IoT Hub → Built-in endpoints → Event Hub-compatible endpoint
#   → Connection string-primary key
#
# Formato: Endpoint=sb://<namespace>.servicebus.windows.net/;
#          SharedAccessKeyName=...;SharedAccessKey=...;EntityPath=<hub-name>
#
IOTHUB_EVENTHUB_CONNECTION_STRING=

# Consumer group (default: $Default)
# Crea un gruppo dedicato per non interferire con altri consumer
IOTHUB_CONSUMER_GROUP=$Default

# ── Azure Digital Twins ───────────────────────────────────────────────────────
#
# Dove trovarlo:  ADT → Overview → Host name  (aggiungi https://)
#
ADT_INSTANCE_URL=https://<your-instance>.api.<region>.digitaltwins.azure.net

# Query KQL per leggere i twin (opzionale – usa il default se vuoto)
# Default: SELECT * FROM DIGITALTWINS WHERE IS_DEFINED(value)
ADT_QUERY=

# Secondi tra un poll e l'altro (default: 10)
ADT_POLL_INTERVAL=10

# ── Autenticazione Azure (Service Principal) ──────────────────────────────────
#
# Necessario solo per ADT via Service Principal.
# In alternativa, DefaultAzureCredential usa az login / Managed Identity.
#
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── Mapping sensori IoT Hub → KPI ────────────────────────────────────────────
#
# Alternativa al file assets/data/sensor-map.json.
# Formato JSON inline:
#   { "deviceId.propertyName": "kpiId", "temperature": "temperature" }
#
SENSOR_MAP_JSON=
